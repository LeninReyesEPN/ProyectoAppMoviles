<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true"
    tools:context=".RegistroActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_crear_cuenta"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/texto_h1"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"
            android:text="@string/registro_subtitulo"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/texto_body" />

        <EditText
            android:id="@+id/txtNombre"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_nombre"
            android:importantForAutofill="no"
            android:inputType="textPersonName"
            android:paddingHorizontal="20dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="@dimen/texto_body" />

        <EditText
            android:id="@+id/txtCedula"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_cedula"
            android:importantForAutofill="no"
            android:inputType="number"
            android:paddingHorizontal="20dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="@dimen/texto_body" />

        <EditText
            android:id="@+id/txtEdad"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_edad"
            android:importantForAutofill="no"
            android:inputType="number"
            android:paddingHorizontal="20dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="@dimen/texto_body" />

        <!-- Campo: Contrasena -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05"
            android:text="@string/label_password"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/texto_label"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min">

            <EditText
                android:id="@+id/txtPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_password"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="64dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="@dimen/texto_body" />

            <ImageButton
                android:id="@+id/btnTogglePassword"
                android:layout_width="@dimen/touch_min"
                android:layout_height="@dimen/touch_min"
                android:layout_gravity="end|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="@string/desc_mostrar_password"
                android:padding="18dp"
                android:src="@drawable/ic_eye_off" />
        </FrameLayout>

        <!-- Campo: Confirmar contrasena -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05"
            android:text="@string/label_confirmar_password"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/texto_label"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min">

            <EditText
                android:id="@+id/txtPasswordConfirmar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_confirmar_password"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="64dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="@dimen/texto_body" />

            <ImageButton
                android:id="@+id/btnTogglePasswordConfirmar"
                android:layout_width="@dimen/touch_min"
                android:layout_height="@dimen/touch_min"
                android:layout_gravity="end|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="@string/desc_mostrar_password"
                android:padding="18dp"
                android:src="@drawable/ic_eye_off" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrarme"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/primary"
            android:text="@string/btn_registrarme"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/texto_body"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radio_boton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnYaTengoCuenta"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/btn_ya_tengo_cuenta"
            android:textAllCaps="false"
            android:textColor="@color/primary_hover"
            android:textSize="@dimen/texto_body" />

    </LinearLayout>
</ScrollView>
