<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_alt"
    android:fillViewport="true"
    tools:context=".HomeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/corazon"
            android:textColor="@color/primary"
            android:textSize="54sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_app"
            android:textColor="@color/primary"
            android:textSize="@dimen/texto_h1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/msgSaludo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:text="@string/home_saludo_generico"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/home_pregunta"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/texto_h2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgendar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/boton_grande"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/primary"
            android:text="@string/btn_agendar"
            android:textSize="@dimen/texto_h2"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radio_boton_grande" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerCitas"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/boton_grande"
            android:layout_marginTop="20dp"
            android:text="@string/btn_ver_citas"
            android:textColor="@color/primary"
            android:textSize="@dimen/texto_h2"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radio_boton_grande"
            app:strokeColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarSesion"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="24dp"
            android:text="@string/btn_cerrar_sesion"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/texto_body" />

    </LinearLayout>
</ScrollView>
