<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true"
    tools:context=".ui.booking.ConfirmacionFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/touch_min"
                android:layout_height="@dimen/touch_min"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle_card"
                android:gravity="center"
                android:text="‹"
                android:textColor="@color/text_primary"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/paso_3_de_3"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_confirmar"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_h1"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:progress="100"
            app:indicatorColor="@color/accent"
            app:trackColor="@color/bg_card"
            app:trackCornerRadius="4dp" />

        <!-- Doctor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvIconoDoctor"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_card"
                android:gravity="center"
                android:text="❤️"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDoctorNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_h2"
                    android:textStyle="bold"
                    tools:text="Dr. Roberto Vargas" />

                <TextView
                    android:id="@+id/tvEspecialidadTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/texto_label"
                    tools:text="Cardiología" />
            </LinearLayout>
        </LinearLayout>

        <!-- Resumen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <include layout="@layout/item_resumen_fila" android:id="@+id/filaFecha" />
            <include layout="@layout/item_resumen_fila" android:id="@+id/filaHora" />
            <include layout="@layout/item_resumen_fila" android:id="@+id/filaModalidad" />
            <include layout="@layout/item_resumen_fila" android:id="@+id/filaDuracion" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/primary"
            android:text="@string/btn_confirmar_cita"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/texto_body"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radio_boton" />

    </LinearLayout>
</ScrollView>
