<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true"
    tools:context=".ui.booking.EspecialidadFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/touch_min"
                android:layout_height="@dimen/touch_min"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle_card"
                android:gravity="center"
                android:text="‹"
                android:textColor="@color/text_primary"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/paso_1_de_3"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_especialidad"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_h1"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:progress="33"
            app:indicatorColor="@color/accent"
            app:trackColor="@color/bg_card"
            app:trackCornerRadius="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardCardiologia"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_selected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_circle_card"
                    android:gravity="center"
                    android:text="❤️"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esp_cardiologia"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/doc_cardiologia"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardMedicinaGeneral"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_circle_card"
                    android:gravity="center"
                    android:text="🩺"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esp_medicina_general"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/doc_medicina_general"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardNeumologia"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_circle_card"
                    android:gravity="center"
                    android:text="🫁"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esp_neumologia"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/doc_neumologia"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardNeurologia"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_circle_card"
                    android:gravity="center"
                    android:text="🧠"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esp_neurologia"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/doc_neurologia"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="⏰"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/disponibilidad_inmediata"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDisponibilidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label"
                    tools:text="Hoy · Medicina General (2 horarios disponibles)" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/primary"
            android:text="@string/btn_continuar_fecha"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/texto_body"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radio_boton" />

    </LinearLayout>
</ScrollView>
