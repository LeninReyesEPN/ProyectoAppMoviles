<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true"
    tools:context=".ui.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Saludo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_buenos_dias"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />

                <TextView
                    android:id="@+id/tvSaludo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_saludo_generico"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_h1"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="@dimen/touch_min"
                android:layout_height="@dimen/touch_min"
                android:background="@drawable/bg_circle_card"
                android:gravity="center"
                android:text="🔔"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Proxima cita -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="📅"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_proxima_cita_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />

                <TextView
                    android:id="@+id/tvProximaCita"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/home_sin_proxima_cita"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.05"
            android:text="@string/home_que_deseas_hacer"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/texto_label"
            android:textStyle="bold" />

        <!-- Agendar cita -->
        <LinearLayout
            android:id="@+id/cardAgendar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/boton_grande"
            android:background="@drawable/bg_card_selected"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_primary"
                android:gravity="center"
                android:text="➕"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_agendar_titulo"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_agendar_subtitulo"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/text_secondary"
                android:textSize="24sp" />
        </LinearLayout>

        <!-- Mis citas -->
        <LinearLayout
            android:id="@+id/cardMisCitas"
            android:layout_width="match_parent"
            android:layout_height="@dimen/boton_grande"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_card"
                android:gravity="center"
                android:text="📅"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_mis_citas_titulo"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_mis_citas_subtitulo"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/text_secondary"
                android:textSize="24sp" />
        </LinearLayout>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="16dp">

                <TextView
                    android:id="@+id/tvStatTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_h1"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_stat_total"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="16dp">

                <TextView
                    android:id="@+id/tvStatAnio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/texto_h1"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_stat_anio"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/texto_label" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
