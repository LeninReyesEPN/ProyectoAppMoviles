<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_alt"
    android:fillViewport="true"
    tools:context=".CitaActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/btnRegresar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="@string/cita_regresar"
            android:textColor="@color/primary"
            android:textSize="@dimen/texto_body" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/cita_titulo"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMedicinaGeneral"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="30dp"
            android:backgroundTint="@color/esp_medicina_general"
            android:text="@string/esp_medicina_general"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/texto_body"
            app:cornerRadius="@dimen/radio_boton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCardiologia"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/esp_cardiologia"
            android:text="@string/esp_cardiologia"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/texto_body"
            app:cornerRadius="@dimen/radio_boton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNeumologia"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/esp_neumologia"
            android:text="@string/esp_neumologia"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/texto_body"
            app:cornerRadius="@dimen/radio_boton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNeurologia"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/esp_neurologia"
            android:text="@string/esp_neurologia"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/texto_body"
            app:cornerRadius="@dimen/radio_boton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_min"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/primary"
            android:text="@string/btn_volver"
            android:textSize="@dimen/texto_body"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radio_boton" />

    </LinearLayout>
</ScrollView>
